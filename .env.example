# Binance API Credentials (Only needed for live market data fetch, can remain empty)
BN_API_KEY=
BN_SECRET=

# LLM Provider Configuration
# Set OPENROUTER_API_KEY to run backtests via OpenRouter
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY_HERE

# Gemini API (Alternative LLM provider)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Trading Strategy Configuration
TRADEBOT_INTERVAL=1d
TRADEBOT_SYSTEM_PROMPT_FILE=prompts/system_prompt.txt

# LLM Model Configuration
TRADEBOT_LLM_MODEL=meta-llama/llama-3.3-70b-instruct
TRADEBOT_LLM_TEMPERATURE=0.2
TRADEBOT_LLM_MAX_TOKENS=3000
TRADEBOT_LLM_THINKING=

# Capital settings
PAPER_START_CAPITAL=1000
SORTINO_RISK_FREE_RATE=0.0

# Telegram notifications (Can remain empty during backtesting)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_SIGNALS_CHAT_ID=

# Hyperliquid Live Trading (Disabled for backtests)
HYPERLIQUID_LIVE_TRADING=false
HYPERLIQUID_WALLET_ADDRESS=
HYPERLIQUID_PRIVATE_KEY=
HYPERLIQUID_CAPITAL=500.0

# Backtest configuration
BACKTEST_SYMBOLS=AAPL
BACKTEST_INTERVAL=1d
BACKTEST_START=2024-01-01
BACKTEST_END=2025-12-31
BACKTEST_START_CAPITAL=1000
BACKTEST_SLIPPAGE_MODE=S0
BACKTEST_RUN_ID=AAPL_BACKTEST_2024_2025_S0
