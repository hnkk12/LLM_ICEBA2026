# Safe backtest-only environment template for anonymous review
# Copy to .env only if re-running code locally. Do not commit real credentials.

# LLM provider credentials, needed only for fresh LLM calls
HOSTED_LLM_API_KEY=REVIEWER_PROVIDED_KEY
HOSTED_LLM_API_URL=https://REVIEWER_CONFIGURED_LLM_ENDPOINT
GEMINI_API_KEY=REVIEWER_PROVIDED_KEY

# Backtest controls
BACKTEST_SYMBOL=AAPL
BACKTEST_DATA_PATH=dataset/AAPL_D_2004_2023.csv
BACKTEST_START=2008-01-01
BACKTEST_END=2009-12-31
BACKTEST_SLIPPAGE_MODE=S0
BACKTEST_RUN_ID=ANONYMOUS_REVIEW_RUN
BACKTEST_MAX_TOKENS=3000

# Model settings
TRADEBOT_LLM_MODEL=meta-llama/llama-3.3-70b-instruct
TRADEBOT_LLM_TEMPERATURE=0.2
TRADEBOT_LLM_MAX_TOKENS=3000

# Review mode: paper/backtest only; live trading disabled
TRADEBOT_LIVE_TRADING=false
